      "label": "Train in under 120 minutes"
    },
    {
      "metric": "modelFreshness",
      "operator": ">=",
      "value": 70,
      "label": "Model freshness ≥ 70%"
    },
    {
      "metric": "reliability",
      "operator": ">=",
      "value": 97,
      "label": "97%+ system uptime"
    },
    {
      "metric": "infraCost",
