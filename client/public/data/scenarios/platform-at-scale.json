      "unit": "%",
      "label": "Model Freshness",
      "lowerIsBetter": false,
      "cap": 100
    },
    "reliability": {
      "base": 92,
      "unit": "%",
      "label": "System Uptime",
      "lowerIsBetter": false,
      "cap": 99.99
    },
    "infraCost": {
      "base": 0,
      "unit": "$/mo",
      "label": "Infra Cost",
      "lowerIsBetter": true
    }
  },
  "goals": [
    {
      "metric": "trainingCost",
      "operator": "<=",
